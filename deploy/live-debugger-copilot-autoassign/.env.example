# ─────────────────────────────────────────────────────────────────────────────
# Live Debugger — Copilot Auto-Assign  •  .env.example
#
# Copy this file to .env and fill in real values.
#   cp .env.example .env
#   docker compose up --build
# ─────────────────────────────────────────────────────────────────────────────

# ── AI provider (choose one) ──────────────────────────────────────────────────
AI_PROVIDER=openai
AI_MODEL=gpt-4o

OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AI...

# ── GitHub Copilot auto-assign ────────────────────────────────────────────────
# Token needs: repo + issues:write scopes
GITHUB_TOKEN=ghp_...
GITHUB_REPO=https://github.com/your-org/my-service

# ── Web UI ────────────────────────────────────────────────────────────────────
WEB_PORT=3000

# ── Dummy server error frequency ─────────────────────────────────────────────
ERROR_INTERVAL_MS=5000

# ── Jira (leave blank to disable) ─────────────────────────────────────────────
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=you@yourorg.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=OPS

# ── Notifications (leave blank to disable) ────────────────────────────────────
# Sent when a Copilot guardrail blocks auto-assign OR retries are exhausted
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
NOTIFY_WEBHOOK_URL=https://your-webhook-receiver/events
