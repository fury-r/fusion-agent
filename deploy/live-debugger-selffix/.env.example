# ─────────────────────────────────────────────────────────────────────────────
# Live Debugger — Self-Fix + GitHub Commit  •  .env.example
#
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# Never commit .env to source control — it contains credentials.
# ─────────────────────────────────────────────────────────────────────────────


# ── AI provider ───────────────────────────────────────────────────────────────
# Supported: openai | anthropic | gemini
AI_PROVIDER=openai
AI_MODEL=gpt-4o

# Provide the key for the chosen provider; the others can stay empty.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=
GEMINI_API_KEY=


# ── GitHub / git ──────────────────────────────────────────────────────────────
# Fine-grained token with: Contents:Read+Write, Pull requests:Read+Write
GITHUB_TOKEN=ghp_...

# Full URL of the repository being monitored / fixed
#   e.g.  https://github.com/your-org/my-service
GITHUB_REPO=https://github.com/your-org/my-service

# Branch that the agent will commit fixes to (created if it doesn't exist)
GIT_BRANCH=fusion-agent/auto-fix

# Branch the PR will target
BASE_BRANCH=main

# ── Host path to your local git clone ─────────────────────────────────────────
# Absolute path on the *host* machine.
# docker-compose mounts this at /repo inside the container.
# The container commits directly into this clone, so use a dedicated clone —
# not your primary working directory.
#
#   git clone https://github.com/your-org/my-service /tmp/my-service-autofixer
#   GIT_REPO_HOST_PATH=/tmp/my-service-autofixer
#
GIT_REPO_HOST_PATH=/tmp/fusion-agent-repo

# Git identity for the auto-generated commits
GIT_AUTHOR_NAME=fusion-agent[bot]
GIT_AUTHOR_EMAIL=fusion-agent@noreply

# GitHub Enterprise: override the API base URL (leave empty for github.com)
GIT_API_BASE_URL=


# ── Docker container to watch ─────────────────────────────────────────────────
# Name or ID of the container whose logs the live debugger will tail.
# Defaults to the dummy-server that ships with this example.
DOCKER_CONTAINER=fusion-live-debugger-dummy


# ── Web UI ────────────────────────────────────────────────────────────────────
WEB_PORT=3000


# ── Error simulation ──────────────────────────────────────────────────────────
# How often the dummy server produces a new error batch (milliseconds).
ERROR_INTERVAL_MS=5000


# ── Jira (optional) ───────────────────────────────────────────────────────────
# A Jira ticket is created for every analysis that triggers a fix attempt.
# Leave blank to skip Jira integration.
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@your-org.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=OPS


# ── Notifications (optional) ──────────────────────────────────────────────────
# Sent when a git guardrail blocks a commit or the fixer fails after retries.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
NOTIFY_WEBHOOK_URL=
