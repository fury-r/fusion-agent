{
  "name": "polyai-agent",
  "version": "1.0.0",
  "description": "AI-powered vibe coder, live debugger, and agent session manager — supports OpenAI, Anthropic, and Google Gemini",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ai-agent": "dist/cli.js",
    "aac": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "REQUIREMENTS.md"
  ],
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "copyfiles -u 1 \"src/web/public/**/*\" dist/",
    "build:watch": "tsc --watch",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "cli",
    "agent",
    "openai",
    "anthropic",
    "gemini",
    "vibe-coder",
    "code-generation",
    "debugger",
    "session-manager"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.7.9",
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "inquirer": "^8.2.6",
    "js-yaml": "^4.1.0",
    "openai": "^4.77.0",
    "ora": "^5.4.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.5",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/diff": "^7.0.2",
    "@types/express": "^4.17.21",
    "@types/inquirer": "^8.2.10",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.7",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "copyfiles": "^2.4.1",
    "globals": "^14.0.0",
    "eslint": "^9.19.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fury-r/ai-agent-cli.git"
  }
}
