OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
AI_PROVIDER=openai
AI_MODEL=gpt-4o
AI_AGENT_PORT=3000

# ── Local LLM (Ollama) ────────────────────────────────────────────────────────
# Set AI_PROVIDER=ollama to use a locally running Ollama instance.
# No API key is required.  Adjust the URL if Ollama is not on localhost.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3

# ── Local LLM (generic OpenAI-compatible server) ──────────────────────────────
# Set AI_PROVIDER=local for LM Studio, llama.cpp, LiteLLM, Jan, etc.
# LOCAL_LLM_BASE_URL=http://localhost:1234/v1
# LOCAL_LLM_MODEL=mistral
# LOCAL_LLM_API_KEY=optional-key
